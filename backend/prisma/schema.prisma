generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ───
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  phone        String    @unique
  role         Role      @default(CUSTOMER)
  address      String?

  cart     Cart?
  orders   Order[]
  createdAt DateTime @default(now())
}

enum Role {
  CUSTOMER
  ADMIN
  DELIVERY
}

// ─── Catégories ───
model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  imageUrl String?
  products Product[]
}

// ─── Produits ───
model Product {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String
  price         Decimal   @db.Decimal(10, 2)
  stockQuantity Int       @default(0)
  imageUrls     Json      @default("[]")
  isActive      Boolean   @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  cartItems  CartItem[]
  orderItems OrderItem[]
  createdAt  DateTime @default(now())
}

// ─── Panier Persistant ───
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id       String @id @default(cuid())
  quantity Int    @default(1)

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ─── Commandes ───
model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique // ex: JOGGA-2026-0001
  totalAmount Decimal  @db.Decimal(10, 2)
  paymentMode String   @default("cash") // "cash" | "mobile_money"
  paidAt      DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items    OrderItem[]
  statuses DeliveryStatus[]
  invoice  Invoice?

  createdAt DateTime @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2) // prix figé au moment de la commande

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ─── Suivi de livraison ───
model DeliveryStatus {
  id        String      @id @default(cuid())
  status    StatusEnum
  note      String?
  eta       DateTime?   // heure d'arrivée estimée
  updatedBy String      // ID de l'admin/livreur

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum StatusEnum {
  CONFIRMED
  PREPARING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

// ─── Facture ───
model Invoice {
  id      String   @id @default(cuid())
  pdfUrl  String?
  sentVia String?  // "whatsapp" | "email"
  sentAt  DateTime?

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
}
