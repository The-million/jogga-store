generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ───
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  phone        String    @unique
  role         Role      @default(CUSTOMER)
  avatarUrl    String?
  birthDate    DateTime?

  cart      Cart?
  orders    Order[]
  addresses Address[]
  reviews   Review[]
  wishlist  WishlistItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  CUSTOMER
  ADMIN
  DELIVERY
}

// ─── Catégories (hiérarchiques) ───
model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  imageUrl String?
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

// ─── Settings (admin-configurable) ───
model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  updatedAt DateTime @updatedAt
}

// ─── Produits ───
model Product {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String
  price         Decimal   @db.Decimal(10, 2)
  comparePrice  Decimal?  @db.Decimal(10, 2)
  stockQuantity Int       @default(0)
  imageUrls     Json      @default("[]")
  isActive      Boolean   @default(true)
  isNew         Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  variants      Json      @default("[]") // [{ name: "Taille", values: ["S","M","L"] }]

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  cartItems    CartItem[]
  orderItems   OrderItem[]
  reviews      Review[]
  wishlistItems WishlistItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Panier Persistant ───
model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id             String @id @default(cuid())
  quantity       Int    @default(1)
  variantLabel   Json?  // { "Taille": "M", "Couleur": "Rouge" }

  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ─── Adresses de livraison ───
model Address {
  id        String  @id @default(cuid())
  label     String  // "Maison", "Bureau", "Autre"
  fullName  String
  phone     String
  street    String
  city      String
  isDefault Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Commandes ───
model Order {
  id          String   @id @default(cuid())
  orderNumber String   @unique // ex: JOGGA-2026-0001
  totalAmount Decimal  @db.Decimal(10, 2)
  paymentMode String   @default("cash") // "cash" | "mobile_money"
  paidAt      DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  addressId String?
  address   Address? @relation(fields: [addressId], references: [id])

  items    OrderItem[]
  statuses DeliveryStatus[]
  invoice  Invoice?

  createdAt DateTime @default(now())
}

model OrderItem {
  id           String  @id @default(cuid())
  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2)
  variantLabel Json?   // { "Taille": "M", "Couleur": "Rouge" }

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// ─── Suivi de livraison ───
model DeliveryStatus {
  id        String      @id @default(cuid())
  status    StatusEnum
  note      String?
  eta       DateTime?   // heure d'arrivée estimée
  updatedBy String      // ID de l'admin/livreur

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum StatusEnum {
  CONFIRMED
  PREPARING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

// ─── Facture ───
model Invoice {
  id      String   @id @default(cuid())
  pdfUrl  String?
  sentVia String?  // "whatsapp" | "email"
  sentAt  DateTime?

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Avis produits ───
model Review {
  id        String  @id @default(cuid())
  rating    Int     // 1 à 5
  comment   String?
  isVisible Boolean @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId]) // un seul avis par utilisateur par produit
}

// ─── Liste de souhaits ───
model WishlistItem {
  id        String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}
